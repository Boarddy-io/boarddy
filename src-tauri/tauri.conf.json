{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Boarddy",
  "version": "0.1.0",
  "identifier": "com.boarddy.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Boarddy",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "visible": true
      },
      {
        "label": "quick_paste",
        "title": "Quick Paste",
        "width": 550,
        "height": 400,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "autocomplete",
        "title": "Autocomplete",
        "width": 300,
        "height": 180,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
